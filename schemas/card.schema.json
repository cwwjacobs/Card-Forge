{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://card-forge.local/schemas/card.schema.json",
  "title": "Card",
  "type": "object",
  "required": [
    "card_id",
    "name",
    "type",
    "status",
    "input",
    "move",
    "output",
    "done_when",
    "stop_if",
    "receipt",
    "permissions",
    "risk_level",
    "token_size",
    "source_origin"
  ],
  "properties": {
    "card_id": { "type": "string" },
    "name": { "type": "string" },
    "type": { "type": "string" },
    "status": { "type": "string" },
    "input": { "type": ["string", "array"] },
    "move": { "type": "string" },
    "output": { "type": ["string", "array"] },
    "done_when": { "type": "string" },
    "stop_if": { "type": "string" },
    "receipt": { "type": "string" },
    "permissions": { "type": ["string", "array"] },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "token_size": {
      "type": "string",
      "enum": ["small", "medium", "large"]
    },
    "source_origin": { "type": "string" },
    "model_compatibility": { "type": "array", "items": { "type": "string" } },
    "used_in_decks": { "type": "array", "items": { "type": "string" } },
    "used_in_stacks": { "type": "array", "items": { "type": "string" } },
    "requires": { "type": "array", "items": { "type": "string" } },
    "unlocks": { "type": "array", "items": { "type": "string" } },
    "duplicate_risk": { "type": "string" },
    "suggested_action": { "type": "string" },
    "index_warning_note": { "type": "string" }
  },
  "additionalProperties": true
}
